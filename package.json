{
  "name": "inboxcfo",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered financial copilot for invoice extraction and cash flow forecasting.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "seed:demo": "node seed-demo.js",
    "project:cashflow": "node backend/cloud_functions/project-cashflow.js",
    "check:js": "node --check seed-demo.js && node --check backend/cloud_functions/project-cashflow.js",
    "check:env": "node -e \"['SUPABASE_URL','SUPABASE_SERVICE_ROLE_KEY'].forEach((key)=>{if(!process.env[key]){console.error('Missing '+key);process.exitCode=1}})\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "dotenv": "^17.4.2"
  }
}
